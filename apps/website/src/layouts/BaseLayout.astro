---
import "../styles/global.css";
import "biz-ui/styles";
import { HeaderReact } from "../components/HeaderReact";
import Footer from "../components/Footer.astro";
import { BizUIProvider } from "../components/BizUIProvider";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Biz UI - React component library built on Radix UI and Tailwind CSS" } = Astro.props;
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <BizUIProvider client:load>
      <HeaderReact currentPath={currentPath} client:load />
      <main>
        <slot />
      </main>
      <Footer />
    </BizUIProvider>
  </body>
</html>
