---
import "../styles/global.css";
import "biz-ui/styles";
import { HeaderReact } from "../components/HeaderReact";
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import { BizUIProvider } from "../components/BizUIProvider";

interface Props {
  title?: string;
  description?: string;
  frontmatter?: { title?: string; description?: string };
}

const { title: propTitle, description: propDescription, frontmatter } = Astro.props;
const title = frontmatter?.title ?? propTitle ?? "Documentation";
const description = frontmatter?.description ?? propDescription ?? "Biz UI documentation";
const currentPath = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Biz UI</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <BizUIProvider client:load>
      <HeaderReact currentPath={currentPath} client:load />
      <div class="flex">
        <Sidebar currentPath={currentPath} />
        <main class="min-h-[calc(100vh-3.5rem)] flex-1 overflow-auto">
          <div class="container mx-auto max-w-3xl px-4 py-10">
            <slot />
          </div>
        </main>
      </div>
      <Footer />
    </BizUIProvider>
  </body>
</html>
