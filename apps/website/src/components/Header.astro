---
interface Props {
  currentPath?: string;
}

const { currentPath = "" } = Astro.props;
const isDocs = currentPath.startsWith("/docs");
const isPlayground = currentPath === "/playground";
---

<header class="sticky top-0 z-50 w-full border-b border-slate-200 bg-white/95 backdrop-blur supports-[backdrop-filter]:bg-white/80 dark:border-slate-800 dark:bg-slate-950/95 dark:supports-[backdrop-filter]:bg-slate-950/80">
  <div class="container mx-auto flex h-14 items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2 font-semibold text-slate-900 dark:text-white">
      <span class="text-xl font-bold">Biz UI</span>
    </a>
    <nav class="flex items-center gap-6" aria-label="Main navigation">
      <a
        href="/"
        class:list={[
          "text-sm font-medium transition-colors hover:text-slate-600 dark:hover:text-slate-300",
          currentPath === "/" ? "text-slate-900 dark:text-white" : "text-slate-500 dark:text-slate-400",
        ]}
      >
        Home
      </a>
      <a
        href="/docs"
        class:list={[
          "text-sm font-medium transition-colors hover:text-slate-600 dark:hover:text-slate-300",
          isDocs ? "text-slate-900 dark:text-white" : "text-slate-500 dark:text-slate-400",
        ]}
      >
        Docs
      </a>
      <a
        href="/playground"
        class:list={[
          "text-sm font-medium transition-colors hover:text-slate-600 dark:hover:text-slate-300",
          isPlayground ? "text-slate-900 dark:text-white" : "text-slate-500 dark:text-slate-400",
        ]}
      >
        Playground
      </a>
      <a
        href="https://github.com/biz-ui/biz-ui"
        target="_blank"
        rel="noopener noreferrer"
        class="text-sm font-medium text-slate-500 transition-colors hover:text-slate-600 dark:text-slate-400 dark:hover:text-slate-300"
        aria-label="GitHub repository"
      >
        GitHub
      </a>
    </nav>
  </div>
</header>
