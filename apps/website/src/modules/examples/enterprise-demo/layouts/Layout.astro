---
import '../../../../styles/globals.css'
import { AppLayout } from '@examples/components/layout'

interface Props {
  title: string
  description?: string
}

const { title, description = 'Enterprise use case examples for Biz UI component library' } = Astro.props
const currentPath = Astro.url.pathname
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="biz-ui antialiased">
    <AppLayout client:only="react" currentPath={currentPath}>
      <slot />
    </AppLayout>
  </body>
</html>
