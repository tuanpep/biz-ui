---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Button, Card, CardContent, Container, Flex, Link, Heading, Body } from "biz-ui";
import { Accessibility, Palette, Component } from "lucide-react";

const snippetAppRaw = `import { OceanThemeProvider, defaultTheme, Button } from 'biz-ui';
import 'biz-ui/styles';

function App() {
  return (
    <OceanThemeProvider theme={defaultTheme}>
      <div className="biz-ui">
        <Button>Click me</Button>
      </div>
    </OceanThemeProvider>
  );
}`;
const snippetApp = snippetAppRaw.replace(/</g, "&lt;").replace(/>/g, "&gt;");
---

<BaseLayout title="Biz UI - React Component Library" description="Production-ready, accessible React UI components built on Radix UI and Tailwind CSS. 70+ components for business applications.">
  <!-- Hero -->
  <section class="border-b border-border bg-gradient-to-b from-muted/30 to-background">
    <Container>
      <Flex direction="col" align="center" className="py-24 md:py-32 gap-6">
        <Heading variant="heading-05" className="text-center">
          Build business UIs with <span class="text-muted-foreground">Biz UI</span>
        </Heading>
        <Body variant="body-01" className="text-center text-muted-foreground max-w-2xl">
          Production-ready, accessible React components built on Radix UI primitives and Tailwind CSS. 70+ components designed for modern business applications.
        </Body>
        <Flex gap={4} wrap="wrap" justify="center" className="mt-6">
          <Button as="a" href="/docs">Get started</Button>
          <Button as="a" href="/playground" variant="secondary">Playground</Button>
          <Button as="a" href="https://github.com/biz-ui/biz-ui" variant="tertiary" target="_blank" rel="noopener noreferrer">GitHub</Button>
        </Flex>
      </Flex>
    </Container>
  </section>

  <!-- Features -->
  <section class="border-b border-border">
    <Container>
      <Flex direction="col" align="center" className="py-20 gap-4">
        <Heading variant="heading-04" className="text-center">
          Why Biz UI?
        </Heading>
        <Flex gap={8} wrap="wrap" justify="center" className="mt-12 max-w-5xl">
          <Card className="max-w-sm flex-1 min-w-[280px]">
            <CardContent className="p-6">
              <Flex className="h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-4">
                <Accessibility className="h-5 w-5 text-primary" />
              </Flex>
              <Heading variant="heading-04" className="mb-2">Accessible</Heading>
              <Body variant="body-sm" className="text-muted-foreground">
                Built on Radix UI primitives with keyboard navigation, focus management, and ARIA attributes. WCAG 2.1 AA aligned.
              </Body>
            </CardContent>
          </Card>
          <Card className="max-w-sm flex-1 min-w-[280px]">
            <CardContent className="p-6">
              <Flex className="h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-4">
                <Palette className="h-5 w-5 text-primary" />
              </Flex>
              <Heading variant="heading-04" className="mb-2">Customizable</Heading>
              <Body variant="body-sm" className="text-muted-foreground">
                Themed with CSS variables and Tailwind. Override tokens, use your design system, or ship with the default theme.
              </Body>
            </CardContent>
          </Card>
          <Card className="max-w-sm flex-1 min-w-[280px]">
            <CardContent className="p-6">
              <Flex className="h-10 w-10 items-center justify-center rounded-lg bg-primary/10 mb-4">
                <Component className="h-5 w-5 text-primary" />
              </Flex>
              <Heading variant="heading-04" className="mb-2">70+ Components</Heading>
              <Body variant="body-sm" className="text-muted-foreground">
                Forms, data display, navigation, feedback, overlays, and layout. Everything you need for dashboards and apps.
              </Body>
            </CardContent>
          </Card>
        </Flex>
      </Flex>
    </Container>
  </section>

  <!-- Installation -->
  <section class="border-b border-border">
    <Container>
      <Flex direction="col" align="center" className="py-20 gap-4">
        <Heading variant="heading-04" className="text-center">
          Quick start
        </Heading>
        <Body variant="body-01" className="text-center text-muted-foreground mt-4">
          Install the package and peer dependencies, then wrap your app with the theme provider.
        </Body>

        <div class="mt-8 w-full max-w-2xl overflow-hidden rounded-xl border border-border bg-slate-900">
          <div class="border-b border-border px-4 py-2 text-xs font-medium text-slate-400 bg-slate-800/50">
            Terminal
          </div>
          <pre class="overflow-x-auto p-4 text-sm text-slate-100"><code>npm install biz-ui react react-dom
# or: yarn add biz-ui react react-dom
# or: pnpm add biz-ui react react-dom
# or: bun add biz-ui react react-dom</code></pre>
        </div>

        <div class="mt-6 w-full max-w-2xl overflow-hidden rounded-xl border border-border bg-slate-900">
          <div class="border-b border-border px-4 py-2 text-xs font-medium text-slate-400 bg-slate-800/50">
            App.tsx
          </div>
          <pre class="overflow-x-auto p-4 text-sm text-slate-100"><code set:html={snippetApp} /></pre>
        </div>

        <Body variant="body-sm" className="mt-6 text-center text-muted-foreground">
          <Link href="/docs">Read the full setup guide</Link> including Tailwind and peer dependencies.
        </Body>
      </Flex>
    </Container>
  </section>

  <!-- CTA -->
  <section>
    <Container>
      <Flex direction="col" align="center" className="py-20 gap-4">
        <Heading variant="heading-04" className="text-center">
          Ready to build?
        </Heading>
        <Body variant="body-01" className="text-center text-muted-foreground">
          Explore components in Storybook or dive into the docs.
        </Body>
        <Flex gap={4} wrap="wrap" justify="center" className="mt-6">
          <Button as="a" href="/docs">Documentation</Button>
          <Button as="a" href="/playground" variant="secondary">Playground</Button>
        </Flex>
      </Flex>
    </Container>
  </section>
</BaseLayout>
