---
import Layout from '@examples/layouts/Layout.astro'
import { InvoiceTable } from '@examples/components/finance'
---

<Layout title="Invoices - Biz UI Enterprise Demo">
  <div class="space-y-6">
    <div class="mb-6">
      <nav class="mb-2 flex items-center gap-1 text-sm text-muted-foreground">
        <span class="text-foreground font-medium">Finance</span>
        <span>/</span>
        <span class="text-foreground font-medium">Invoices</span>
      </nav>
      <h1 class="text-2xl font-semibold text-foreground">Invoices</h1>
      <p class="mt-1 text-sm text-muted-foreground">Manage and track your invoices</p>
    </div>

    <InvoiceTable client:only="react" />
  </div>
</Layout>
