---
import Layout from '@examples/layouts/Layout.astro'
import { Card, CardContent, CardHeader, CardTitle } from 'biz-ui'
import { Badge } from 'biz-ui'
import {
  Table,
  TableBody,
  TableCell,
  TableHead,
  TableHeader,
  TableRow,
} from 'biz-ui'
import { AttendanceFilters } from '@examples/components/hr'
import { attendanceRecords } from '@examples/data'
import { getStatusColor } from '@examples/lib/utils'
import { BASE } from '@examples/constants'
import { CheckCircle, XCircle, Clock, UserX } from 'lucide-react'

const summaryCards = [
  { title: 'Present', value: 5, icon: 'CheckCircle', color: 'text-success' },
  { title: 'Absent', value: 1, icon: 'XCircle', color: 'text-destructive' },
  { title: 'Late', value: 1, icon: 'Clock', color: 'text-warning' },
  { title: 'On Leave', value: 1, icon: 'UserX', color: 'text-info' },
]
---

<Layout title="Attendance - Biz UI Enterprise Demo">
  <div class="space-y-6">
    <div class="flex items-center justify-between mb-6">
      <div>
        <nav class="mb-2 flex items-center gap-1 text-sm text-muted-foreground">
          <a href={BASE + '/hr'} class="hover:text-foreground transition-colors">HR</a>
          <span>/</span>
          <span class="text-foreground font-medium">Attendance</span>
        </nav>
        <h1 class="text-2xl font-semibold text-foreground">Attendance</h1>
        <p class="mt-1 text-sm text-muted-foreground">Track employee attendance and working hours</p>
      </div>
      <AttendanceFilters client:only="react" />
    </div>

    <div class="grid gap-4 md:grid-cols-4">
      {summaryCards.map((card) => (
        <Card>
          <CardHeader class="flex flex-row items-center justify-between pb-2">
            <CardTitle class="text-sm font-medium text-muted-foreground">
              {card.title}
            </CardTitle>
            {card.icon === 'CheckCircle' && <CheckCircle class="h-4 w-4 text-success" />}
            {card.icon === 'XCircle' && <XCircle class="h-4 w-4 text-destructive" />}
            {card.icon === 'Clock' && <Clock class="h-4 w-4 text-warning" />}
            {card.icon === 'UserX' && <UserX class="h-4 w-4 text-info" />}
          </CardHeader>
          <CardContent>
            <div class:list={["text-2xl font-bold", card.color]}>{card.value}</div>
          </CardContent>
        </Card>
      ))}
    </div>

    <Card>
      <CardHeader>
        <CardTitle>Today's Attendance</CardTitle>
      </CardHeader>
      <CardContent class="p-0">
        <Table>
          <TableHeader>
            <TableRow>
              <TableHead>Employee</TableHead>
              <TableHead>Status</TableHead>
              <TableHead>Check In</TableHead>
              <TableHead>Check Out</TableHead>
              <TableHead>Working Hours</TableHead>
            </TableRow>
          </TableHeader>
          <TableBody>
            {attendanceRecords.map((record) => (
              <TableRow>
                <TableCell class="font-medium">{record.employeeName}</TableCell>
                <TableCell>
                  <Badge variant={getStatusColor(record.status) as 'default' | 'secondary' | 'destructive' | 'outline'}>
                    {record.status}
                  </Badge>
                </TableCell>
                <TableCell>{record.checkIn || '-'}</TableCell>
                <TableCell>{record.checkOut || '-'}</TableCell>
                <TableCell>
                  {record.checkIn && record.checkOut
                    ? `${(parseFloat(record.checkOut.split(':')[0]) - parseFloat(record.checkIn.split(':')[0]))}h`
                    : '-'}
                </TableCell>
              </TableRow>
            ))}
          </TableBody>
        </Table>
      </CardContent>
    </Card>
  </div>
</Layout>
