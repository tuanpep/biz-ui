---
import Layout from '@examples/layouts/Layout.astro'
import { Card, CardContent, CardHeader, CardTitle } from 'biz-ui'
import { PageHeader } from '@examples/components/layout'
import { ChartCard } from '@examples/components/charts'
import { AreaChart } from '@examples/components/charts'
import { BarChart } from '@examples/components/charts'
import { MetricCards, RecentActivityTable, DashboardControls } from '@examples/components/dashboard'
import { dashboardMetrics, revenueData, userGrowthData, trafficSourceData, recentActivity } from '@examples/data'
---

<Layout title="Dashboard - Biz UI Enterprise Demo">
  <div class="space-y-6">
    <PageHeader
      title="Dashboard"
      description="Overview of your business metrics and recent activity"
      breadcrumbs={[{ label: 'Dashboard' }]}
      client:load
    />

    <DashboardControls client:only="react" />

    <MetricCards metrics={dashboardMetrics} client:only="react" />

    <div class="grid gap-6 lg:grid-cols-2">
      <ChartCard title="Revenue" description="Monthly revenue comparison" client:only="react">
        <AreaChart data={revenueData} showPrevious client:visible />
      </ChartCard>
      <ChartCard title="User Growth" description="Monthly active users" client:only="react">
        <AreaChart data={userGrowthData} client:visible />
      </ChartCard>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      <ChartCard title="Traffic Sources" client:only="react">
        <BarChart data={trafficSourceData} height={250} client:visible />
      </ChartCard>
      <div class="lg:col-span-2">
        <Card>
          <CardHeader>
            <CardTitle>Recent Activity</CardTitle>
          </CardHeader>
          <CardContent>
            <RecentActivityTable activities={recentActivity} client:only="react" />
          </CardContent>
        </Card>
      </div>
    </div>
  </div>
</Layout>
