---
import Layout from '@examples/layouts/Layout.astro'
import { DealPipeline } from '@examples/components/crm'
---

<Layout title="Deal Pipeline - Biz UI Enterprise Demo">
  <div class="space-y-6">
    <div class="mb-6">
      <nav class="mb-2 flex items-center gap-1 text-sm text-muted-foreground">
        <span class="text-foreground font-medium">CRM</span>
        <span>/</span>
        <span class="text-foreground font-medium">Deal Pipeline</span>
      </nav>
      <h1 class="text-2xl font-semibold text-foreground">Deal Pipeline</h1>
      <p class="mt-1 text-sm text-muted-foreground">Track and manage your sales opportunities</p>
    </div>

    <DealPipeline client:only="react" />
  </div>
</Layout>
