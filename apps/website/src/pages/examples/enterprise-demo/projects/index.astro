---
import Layout from '@examples/layouts/Layout.astro'
import { ProjectList } from '@examples/components/projects'
---

<Layout title="Projects - Biz UI Enterprise Demo">
  <div class="space-y-6">
    <div class="mb-6">
      <nav class="mb-2 flex items-center gap-1 text-sm text-muted-foreground">
        <span class="text-foreground font-medium">Projects</span>
        <span>/</span>
        <span class="text-foreground font-medium">All Projects</span>
      </nav>
      <h1 class="text-2xl font-semibold text-foreground">Projects</h1>
      <p class="mt-1 text-sm text-muted-foreground">Manage and track your team's projects</p>
    </div>

    <ProjectList client:only="react" />
  </div>
</Layout>
