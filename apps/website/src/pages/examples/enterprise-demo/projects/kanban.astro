---
import Layout from '@examples/layouts/Layout.astro'
import { ProjectKanban } from '@examples/components/projects'
---

<Layout title="Kanban Board - Biz UI Enterprise Demo">
  <div class="space-y-6">
    <div class="mb-6">
      <nav class="mb-2 flex items-center gap-1 text-sm text-muted-foreground">
        <span class="text-foreground font-medium">Projects</span>
        <span>/</span>
        <span class="text-foreground font-medium">Kanban Board</span>
      </nav>
      <h1 class="text-2xl font-semibold text-foreground">Kanban Board</h1>
      <p class="mt-1 text-sm text-muted-foreground">Visualize and manage project tasks</p>
    </div>

    <ProjectKanban client:only="react" />
  </div>
</Layout>
