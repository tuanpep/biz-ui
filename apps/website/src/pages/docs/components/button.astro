---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import ButtonPreview from "../../../components/preview/ButtonPreview";
import { Heading, Body } from "biz-ui";

const snippet = `import { Button } from 'biz-ui';

<Button>Primary</Button>
<Button variant="secondary">Secondary</Button>
<Button variant="tertiary">Tertiary>
<Button loading>Loading...</Button>`;
const snippetEscaped = snippet.replace(/</g, "&lt;").replace(/>/g, "&gt;");
---

<DocsLayout title="Button" description="Button component - variants, sizes, loading state">
  <article>
    <Heading variant="heading-02">Button</Heading>
    <Body variant="body-lg" className="mt-4 text-muted-foreground">
      Buttons trigger actions. Biz UI Button supports variants (primary, secondary, tertiary), sizes, loading state, and icons.
    </Body>

    <Heading variant="heading-04" className="mt-10">Examples</Heading>
    <div class="mt-4 rounded-lg border border-border bg-muted/30 p-6">
      <ButtonPreview client:load />
    </div>

    <Heading variant="heading-04" className="mt-10">Usage</Heading>
    <pre class="mt-4 overflow-x-auto rounded-lg border border-border bg-slate-900 p-4 text-sm text-slate-100"><code set:html={snippetEscaped}></code></pre>

    <Heading variant="heading-04" className="mt-10">Props</Heading>
    <div class="mt-4 overflow-x-auto rounded-lg border border-border">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-muted/50">
            <th class="px-4 py-3 text-left font-medium text-foreground">Prop</th>
            <th class="px-4 py-3 text-left font-medium text-foreground">Type</th>
            <th class="px-4 py-3 text-left font-medium text-foreground">Default</th>
            <th class="px-4 py-3 text-left font-medium text-foreground">Description</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <tr>
            <td class="px-4 py-3 font-mono text-foreground">variant</td>
            <td class="px-4 py-3 text-muted-foreground">primary | secondary | tertiary | ghost | danger</td>
            <td class="px-4 py-3 text-muted-foreground">primary</td>
            <td class="px-4 py-3 text-muted-foreground">Visual style</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-mono text-foreground">size</td>
            <td class="px-4 py-3 text-muted-foreground">sm | md | lg</td>
            <td class="px-4 py-3 text-muted-foreground">md</td>
            <td class="px-4 py-3 text-muted-foreground">Button size</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-mono text-foreground">loading</td>
            <td class="px-4 py-3 text-muted-foreground">boolean</td>
            <td class="px-4 py-3 text-muted-foreground">false</td>
            <td class="px-4 py-3 text-muted-foreground">Shows spinner and disables button</td>
          </tr>
          <tr>
            <td class="px-4 py-3 font-mono text-foreground">disabled</td>
            <td class="px-4 py-3 text-muted-foreground">boolean</td>
            <td class="px-4 py-3 text-muted-foreground">false</td>
            <td class="px-4 py-3 text-muted-foreground">Disables the button</td>
          </tr>
        </tbody>
      </table>
    </div>
  </article>
</DocsLayout>
