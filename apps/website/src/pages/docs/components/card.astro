---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import CardPreview from "../../../components/preview/CardPreview";
import { Heading, Body } from "biz-ui";

const snippet = `import { Card } from 'biz-ui';

<Card>
  <CardHeader>
    <CardTitle>Title</CardTitle>
  </CardHeader>
  <CardContent>Content here.</CardContent>
</Card>`;
const snippetEscaped = snippet.replace(/</g, "&lt;").replace(/>/g, "&gt;");
---

<DocsLayout title="Card" description="Card component for grouping content">
  <article>
    <Heading variant="heading-02">Card</Heading>
    <Body variant="body-lg" className="mt-4 text-muted-foreground">
      Card groups content with optional header and footer. Use for panels, dashboards, and content blocks.
    </Body>

    <Heading variant="heading-04" className="mt-10">Examples</Heading>
    <div class="mt-4 rounded-lg border border-border bg-muted/30 p-6">
      <CardPreview client:load />
    </div>

    <Heading variant="heading-04" className="mt-10">Usage</Heading>
    <pre class="mt-4 overflow-x-auto rounded-lg border border-border bg-slate-900 p-4 text-sm text-slate-100"><code set:html={snippetEscaped}></code></pre>
  </article>
</DocsLayout>
