---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import AlertPreview from "../../../components/preview/AlertPreview";
import { Heading, Body } from "biz-ui";

const snippet = `import { Alert } from 'biz-ui';

<Alert variant="info" title="Info">Something you should know.</Alert>
<Alert variant="error" title="Error">Something went wrong.</Alert>`;
const snippetEscaped = snippet.replace(/</g, "&lt;").replace(/>/g, "&gt;");
---

<DocsLayout title="Alert" description="Alert component for feedback messages">
  <article>
    <Heading variant="heading-02">Alert</Heading>
    <Body variant="body-lg" className="mt-4 text-muted-foreground">
      Alerts display short feedback messages. Supports variants: info, success, warning, error.
    </Body>

    <Heading variant="heading-04" className="mt-10">Examples</Heading>
    <div class="mt-4 rounded-lg border border-border bg-muted/30 p-6">
      <AlertPreview client:load />
    </div>

    <Heading variant="heading-04" className="mt-10">Usage</Heading>
    <pre class="mt-4 overflow-x-auto rounded-lg border border-border bg-slate-900 p-4 text-sm text-slate-100"><code set:html={snippetEscaped}></code></pre>
  </article>
</DocsLayout>
