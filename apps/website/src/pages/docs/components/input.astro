---
import DocsLayout from "../../../layouts/DocsLayout.astro";
import InputPreview from "../../../components/preview/InputPreview";
import { Heading, Body, Link } from "biz-ui";

const snippet = `import { Input, Label } from 'biz-ui';

<Label htmlFor="email">Email</Label>
<Input id="email" type="email" placeholder="you@example.com" />`;
const snippetEscaped = snippet.replace(/</g, "&lt;").replace(/>/g, "&gt;");
---

<DocsLayout title="Input" description="Input component for text fields">
  <article>
    <Heading variant="heading-02">Input</Heading>
    <Body variant="body-lg" className="mt-4 text-muted-foreground">
      Text input with support for labels, placeholder, disabled state, and error styling.
    </Body>

    <Heading variant="heading-04" className="mt-10">Examples</Heading>
    <div class="mt-4 rounded-lg border border-border bg-muted/30 p-6">
      <InputPreview client:load />
    </div>

    <Heading variant="heading-04" className="mt-10">Usage</Heading>
    <pre class="mt-4 overflow-x-auto rounded-lg border border-border bg-slate-900 p-4 text-sm text-slate-100"><code set:html={snippetEscaped}></code></pre>

    <Heading variant="heading-04" className="mt-10">Props</Heading>
    <Body variant="body-md" className="mt-2 text-muted-foreground">
      Input extends native HTML input attributes. Key props: <code class="rounded bg-muted px-1">placeholder</code>, <code class="rounded bg-muted px-1">disabled</code>, <code class="rounded bg-muted px-1">className</code>.
    </Body>
  </article>
</DocsLayout>
