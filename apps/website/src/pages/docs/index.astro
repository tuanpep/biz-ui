---
import DocsLayout from "../../layouts/DocsLayout.astro";
import { Heading, Body, Link } from "biz-ui";
---

<DocsLayout title="Documentation" description="Biz UI documentation - getting started and component reference">
  <article>
    <Heading variant="heading-02">Documentation</Heading>
    <Body variant="body-lg" className="mt-4 text-muted-foreground">
      Biz UI is a React component library built on Radix UI primitives and Tailwind CSS. It provides 70+ accessible, customizable components for business applications.
    </Body>
    <Heading variant="heading-04" className="mt-10">Getting started</Heading>
    <Body variant="body-md" className="mt-2 text-muted-foreground">
      <Link href="/docs/getting-started">Installation and setup</Link> — Install the package, configure Tailwind, and wrap your app with the theme provider.
    </Body>
    <Heading variant="heading-04" className="mt-10">Components</Heading>
    <Body variant="body-md" className="mt-2 text-muted-foreground">
      Browse the component reference for usage, props, and examples:
    </Body>
    <ul class="mt-4 list-inside list-disc space-y-2 text-muted-foreground">
      <li><Link href="/docs/components/button">Button</Link></li>
      <li><Link href="/docs/components/input">Input</Link></li>
      <li><Link href="/docs/components/card">Card</Link></li>
      <li><Link href="/docs/components/alert">Alert</Link></li>
    </ul>
  </article>
</DocsLayout>
